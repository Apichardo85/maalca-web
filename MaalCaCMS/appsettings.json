{
  "$schema": "https://json.schemastore.org/appsettings.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "d8d0e7c9-9c6e-4f5a-9d8e-3f4c5b6a7b8c",
        "SanitizeTinyMce": true
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "DeliveryApi": {
        "Enabled": true,
        "PublicAccess": true,
        "DisableAccessRestrictions": true,
        "ApiKey": "maalca-api-key-2024",
        "MemberAuthorization": {
          "Enabled": false
        },
        "RichTextOutputAsJson": true,
        "OutputExpansionStrategy": "ExpandAll"
      }
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=|DataDirectory|MaalCaCMS.db;",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.Sqlite"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Azure": {
    "CognitiveServices": {
      "Search": {
        "Endpoint": "https://YOUR_SEARCH_SERVICE_NAME.search.windows.net",
        "ApiKey": "YOUR_SEARCH_API_KEY",
        "IndexName": "content-index"
      }
    }
  }
}
