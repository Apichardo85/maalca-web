# ─── MaalCa Web — Environment Variables ───
# Copy to .env.local and fill in your values

# ─── API Backend ───
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
# NEXT_PUBLIC_API_TIMEOUT=30000
# NEXT_PUBLIC_API_DEBUG=false

# ─── Umbraco CMS (Delivery API) ───
NEXT_PUBLIC_UMBRACO_URL=http://localhost:5011

# ─── Google Analytics 4 ───
# Get from: https://analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX

# ─── Resend (Email / Newsletter) ───
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Optional: Resend audience ID for contact storage
# RESEND_AUDIENCE_ID=
# Optional: From email (default: MaalCa <noreply@maalca.com>)
# RESEND_FROM_EMAIL=MaalCa <noreply@maalca.com>

# ─── n8n Webhooks (Automation) ───
# N8N_WEBHOOK_URL=https://maalca-agents.up.railway.app/webhook
# N8N_WEBHOOK_SECRET=your-webhook-secret
# N8N_WEBHOOK_TIMEOUT=10000

# ─── Mapbox (Properties Map) ───
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxxxxxxxxx
