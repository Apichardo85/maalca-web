# ===========================================
# maalca-web Environment Variables
# ===========================================

# maalca-api (.NET 8 backend on Railway)
NEXT_PUBLIC_API_BASE_URL=https://maalca-api.up.railway.app
JWT_SECRET=

# maalca-cms (Umbraco 17 on Railway)
UMBRACO_API_URL=https://maalca-cms.up.railway.app
UMBRACO_API_KEY=
NEXT_PUBLIC_UMBRACO_MEDIA_URL=https://maalca-cms.up.railway.app/media

# n8n Agent Board (Railway)
N8N_WEBHOOK_URL=https://maalca-agents.up.railway.app/webhook
N8N_WEBHOOK_SECRET=
WHATSAPP_NUMBER=16078574226

# ── Content Pipeline ──
# ElevenLabs (voice generation)
ELEVENLABS_API_KEY=

# HeyGen (avatar video generation)
HEYGEN_API_KEY=

# Anthropic (script generation via Claude)
ANTHROPIC_API_KEY=
CONTENT_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# FFmpeg microservice (video post-production)
FFMPEG_SERVICE_URL=

# Content pipeline timeout (ms)
CONTENT_PIPELINE_TIMEOUT=30000

# YouTube Data API v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# TikTok Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# Instagram Graph API (via Facebook)
INSTAGRAM_USER_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
