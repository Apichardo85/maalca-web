    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.github.com/repos/{{ $('Parse Claude Response').item.json.repo }}/issues/{{ $('Parse Claude Response').item.json.issueNumber }}/comments",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "githubApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/vnd.github.v3+json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"body\": \"## Architect Agent: Approved\\n\\n{{ $('Parse Claude Response').item.json.reasoning }}\\n\\n### ADR Created\\n- **File:** `docs/adr/{{ $('Parse Claude Response').item.json.adrTitle }}.md`\\n- **Affected repos:** {{ ($('Parse Claude Response').item.json.affectedRepos || []).join(', ') }}\\n\\n### Risks\\n{{ ($('Parse Claude Response').item.json.risks || []).map(r => '- ' + r).join('\\n') }}\\n\\n---\\n_Automated by MaalCa Architect Agent_\"\n}",
        "options": {}
      },
      "id": "comment-approved",
      "name": "Comment: Approved",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2260, 160],
