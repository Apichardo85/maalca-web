        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"message\": \"docs: add {{ $json.adrTitle }} (architect-agent)\",\n  \"content\": \"{{ Buffer.from($json.adrContent || '').toString('base64') }}\",\n  \"branch\": \"main\"\n}",
        "options": {}
      },
      "id": "create-adr-file",
      "name": "Create ADR via GitHub API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2020, 160],
      "credentials": {
        "githubApi": {
          "id": "github-credential",
          "name": "GitHub API"
        }
