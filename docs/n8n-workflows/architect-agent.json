        "jsonBody": "={\n  \"body\": \"## Architect Agent: Rejected\\n\\n{{ $json.reasoning }}\\n\\n### Suggested Alternative\\n{{ $json.alternative }}\\n\\n### Risks Identified\\n{{ ($json.risks || []).map(r => '- ' + r).join('\\n') }}\\n\\n### Affected Repos\\n{{ ($json.affectedRepos || []).map(r => '- ' + r).join('\\n') }}\\n\\n---\\n_Automated by MaalCa Architect Agent — please address the concerns above and remove `needs-decision` when resolved._\"\n}",
        "options": {}
      },
      "id": "comment-rejected",
      "name": "Comment: Rejected",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2020, 460],
      "credentials": {
