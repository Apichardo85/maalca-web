            }
          ],
          "combinator": "and"
        }
      },
      "id": "decision-switch",
      "name": "IF Approved",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1760, 300]
    },
    {
      "parameters": {
